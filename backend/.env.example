# Backend environment variables
# Copy this file to backend/.env and adjust as needed.

# SQLAlchemy URL. For local SQLite use this default value.
DATABASE_URL=sqlite:///./edupredict.db

# JWT settings
JWT_SECRET_KEY=change-this-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated frontend origins for CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
